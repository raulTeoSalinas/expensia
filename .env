# URL base del backend (sin barra final).
# En Expo solo las variables con prefijo EXPO_PUBLIC_ están disponibles en el cliente.
#
# Desarrollo en el mismo ordenador (simulador iOS / emulador Android):
EXPO_PUBLIC_API_URL=https://raul-salinas.dev
#
# Dispositivo físico o emulador que no resuelve "localhost" al PC:
# EXPO_PUBLIC_API_URL=http://192.168.1.x:3000
#
# Tras cambiar este archivo: reinicia Metro (npx expo start) para que cargue los valores.
