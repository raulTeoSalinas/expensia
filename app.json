{
  "expo": {
    "name": "Expensia",
    "slug": "expensia",
    "version": "1.0.1",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#06002e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.raul-salinas.expensia",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "PORTRAIT"
        }
      ],
      "expo-font",
      "expo-asset",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Expensia needs access to your microphone to record your voice transactions."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Expensia needs access to your camera to take photos of receipts and extract transaction details.",
          "microphonePermission": false,
          "photosPermission": "Expensia needs access to your photo library to upload receipt images and extract transaction details."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff",
        "supportsRtl": true
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "bc0de4e4-0744-495b-bb3e-6da6bbb7c784"
      }
    },
    "owner": "lesnoy",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/bc0de4e4-0744-495b-bb3e-6da6bbb7c784"
    },
    "newArchEnabled": true
  }
}
